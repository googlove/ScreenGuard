<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="?attr/colorPrimary"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="20sp"
            style="?attr/buttonStyle" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📸 Захоплені знімки"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="18sp"
            android:paddingStart="16dp" />

        <Button
            android:id="@+id/refreshButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🔄"
            android:textSize="20sp"
            style="?attr/buttonStyle" />

    </LinearLayout>

    <!-- Storage Info -->
    <TextView
        android:id="@+id/storageInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Знімки: 0 | Розмір: 0 MB"
        android:padding="12dp"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurface"
        android:background="?attr/colorSurface" />

    <!-- Grid View -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/capturesGridView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Немає захоплених знімків"
        android:textSize="16sp"
        android:gravity="center"
        android:textColor="?attr/colorOnSurfaceVariant" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminate="true" />

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:spacing="8dp">

        <Button
            android:id="@+id/uploadAllButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📤 Відправити все"
            android:textSize="12sp" />

        <Button
            android:id="@+id/clearAllButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗑️ Видалити все"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
